{
  "name": "create-foldkit-app",
  "version": "0.1.0-canary.1",
  "description": "Create Foldkit applications with no build configuration",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-foldkit-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "pnpm run clean && tsc -b",
    "watch": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.46.1",
    "effect": "^3.16.8",
    "fs-extra": "^11.2.0",
    "chalk": "^5.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "create-foldkit-app",
    "foldkit",
    "scaffolding",
    "effect",
    "cli",
    "template"
  ],
  "author": "Devin Jameson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devinjameson/foldkit.git",
    "directory": "packages/create-foldkit-app"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
